# ==============================================================
# TN-MBNR TrustReg Platform - PRODUCTION CONFIGURATION
# ==============================================================
# This environment is strictly for LIVE traffic.
NODE_ENV=production
PORT=3001

# 1. Database Configuration
# Dedicated Production MongoDB Cluster
MONGODB_URI="mongodb+srv://prod_user:prod_pass@cluster-prod.mongodb.net/tn_mbnr_prod"

# 2. AI Security
VITE_GEMINI_API_KEY="production-api-key"

# 3. Communications (Production accounts)
TWILIO_ACCOUNT_SID="prod_sid"
TWILIO_AUTH_TOKEN="prod_token"
TWILIO_PHONE_NUMBER="+1987654321"
SENDGRID_API_KEY="prod_sg_key"
SENDGRID_FROM_EMAIL="alerts@tn-mbnr.gov.in"

# 4. Cryptography Keys
QR_SECRET_KEY="MBNR_PROD_SECRET_KEY_SECURE_999"
AUTH_SECRET="MBNR_PROD_AUTH_SECRET_SECURE_888"
